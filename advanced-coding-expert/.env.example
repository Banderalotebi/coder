# TechPartner AI Coder - Environment Variables
# Copy this to .env and fill in your values

# Admin Secret (shared with Node.js backend)
ADMIN_SECRET=Admin@6565

# Optional: Blackbox AI API Key (for external LLM)
# Get your API key from https://blackbox.ai
# BLACKBOX_API_KEY=your_api_key_here

# Optional: Groq API Key (faster alternative)
# Get your API key from https://console.groq.com
# GROQ_API_KEY=your_groq_key_here

# Ollama Settings (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2:7b

# RAG Settings
CHROMA_DB_PATH=./data/chromadb
EMBEDDING_MODEL=nomic-embed-text

# Server Settings
API_PORT=8000
NODEJS_BACKEND_URL=http://localhost:8080

